---
import { getCollection } from 'astro:content';
import ArchivePager from '../components/ArchivePager.astro';
import PostStream from '../components/PostStream.astro';
import EntryPage from '../layouts/EntryPage.astro';
import { POSTS_PER_PAGE, getTotalPages, sortPosts } from '../lib/posts';

const description = 'Field notes on software, systems, and the details worth writing down.';
const heading = 'Fighting my fear of being wrong in public, in public.';

const allPosts = sortPosts(await getCollection('posts'));
const posts = allPosts.slice(0, POSTS_PER_PAGE);
const total = allPosts.length;
const totalPages = getTotalPages(total);
---

<EntryPage title="Writing — Field Notes" description={description} heading={heading} headingClass="lead" contentClass="page-end">
	<PostStream posts={posts} total={total} showNewPostArrow={true} />
	<ArchivePager currentPage={1} totalPages={totalPages} />
</EntryPage>

---
import Layout from './Layout.astro';

interface Byline {
	date: string;
	topic?: string;
}

interface Props {
	title: string;
	description: string;
	heading: string;
	headingClass?: string;
	deck?: string;
	byline?: Byline;
	contentClass?: string;
	hasToc?: boolean;
}

const { title, description, heading, headingClass, deck, byline, contentClass, hasToc } = Astro.props;
---

<Layout title={title} description={description}>
	<main class:list={["post", { "has-toc": hasToc }]} id="top">
		<article>
			<header class="entry col">
				{byline && (
					<div class="kicker">
						<nav class="crumb" aria-label="Breadcrumb">
							<a href="/">writing</a>
							{byline.topic && <span class="sep">/</span>}
							{byline.topic && <span class="cur">{byline.topic}</span>}
						</nav>
						<div class="byline">written on <time datetime={byline.date}>{byline.date}</time></div>
					</div>
				)}
				<h1 class:list={["title", headingClass]}>{heading}</h1>
				{deck && <p class="deck">{deck}</p>}
			</header>

			<div class:list={["col", contentClass]}>
				<slot />
			</div>
		</article>
	</main>
</Layout>

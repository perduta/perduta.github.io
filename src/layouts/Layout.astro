---
import '../styles/global.css';

interface Props {
	title: string;
	description: string;
	/* load the Caveat handwriting font (only the index's "new post" arrow uses it) */
	handwritingFont?: boolean;
}

const { title, description, handwritingFont = false } = Astro.props;

const path = Astro.url.pathname;
const onWriting = path === '/' || path.startsWith('/posts') || path.startsWith('/page');
const onAbout = path.startsWith('/about');
---

<!doctype html>
<html lang="en" data-theme="light">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@400;500;600&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,500;0,8..60,600;1,8..60,400&display=swap"
			rel="stylesheet"
		/>
		{handwritingFont && (
			<link
				href="https://fonts.googleapis.com/css2?family=Caveat:wght@600;700&display=swap"
				rel="stylesheet"
			/>
		)}
		<title>{title}</title>
		<script is:inline>
			(function () {
				try {
					var stored = localStorage.getItem('theme');
					var theme =
						stored ||
						(window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
					document.documentElement.setAttribute('data-theme', theme);
				} catch (error) {}
			})();
		</script>
	</head>
	<body>
		<div class="progress" id="progress"></div>

		<header class="site">
			<div class="site-inner">
				<a class="brand" href="/">
					<span class="mark" aria-hidden="true"></span>
					<span class="btxt">
						<span class="bname">Field Notes</span>
						<span class="bsub">by Patryk Perduta</span>
					</span>
				</a>
				<nav class="nav" aria-label="Site">
					<a href="/" aria-current={onWriting ? 'page' : undefined}>writing</a>
					<a href="/about/" aria-current={onAbout ? 'page' : undefined}>about</a>
				</nav>
				<button class="toggle" id="theme" type="button" aria-label="Toggle dark mode">
					<svg class="sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="4.2"></circle><path d="M12 2.5v2.5M12 19v2.5M4.2 4.2l1.8 1.8M18 18l1.8 1.8M2.5 12H5M19 12h2.5M4.2 19.8L6 18M18 6l1.8-1.8"></path></svg>
					<svg class="moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 14.5A8 8 0 1 1 9.5 4a6.4 6.4 0 0 0 10.5 10.5z"></path></svg>
				</button>
			</div>
		</header>

		<slot />

		<script>
			const root = document.documentElement;
			const themeToggle = document.querySelector<HTMLButtonElement>('#theme');

			if (themeToggle) {
				const syncThemeState = () => {
					themeToggle.setAttribute(
						'aria-pressed',
						root.getAttribute('data-theme') === 'dark' ? 'true' : 'false',
					);
				};

				syncThemeState();
				themeToggle.addEventListener('click', () => {
					const next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
					root.setAttribute('data-theme', next);
					syncThemeState();
					try {
						localStorage.setItem('theme', next);
					} catch (error) {}
				});
			}

			const progress = document.querySelector<HTMLElement>('#progress');
			if (progress) {
				let ticking = false;
				const updateProgress = () => {
					ticking = false;
					const scrollable = document.documentElement.scrollHeight - window.innerHeight;
					progress.style.width = `${scrollable > 0 ? (window.scrollY / scrollable) * 100 : 0}%`;
				};
				const requestProgressUpdate = () => {
					if (!ticking) {
						ticking = true;
						window.requestAnimationFrame(updateProgress);
					}
				};
				window.addEventListener('scroll', requestProgressUpdate, { passive: true });
				window.addEventListener('resize', requestProgressUpdate);
				updateProgress();
			}

			document.querySelectorAll<HTMLElement>('figure.code').forEach((figure) => {
				const button = figure.querySelector<HTMLButtonElement>('.copy');
				const pre = figure.querySelector<HTMLElement>('pre');
				if (!button || !pre) return;
				button.addEventListener('click', async () => {
					await navigator.clipboard.writeText(pre.innerText);
					button.textContent = 'copied';
					button.classList.add('done');
					window.setTimeout(() => {
						button.textContent = 'copy';
						button.classList.remove('done');
					}, 1600);
				});
			});

			// Tier-2 rhythm snap (see --cell/--rhythm-phase in global.css): blocks with
			// arbitrary heights — the masthead, inline TOC, figures, code shells,
			// tables, callouts — de-phase the prose that follows them. For each one,
			// nudge its own top margin so its border sits exactly on a lattice rule,
			// and its bottom margin so the following flow re-enters the grid at
			// --rhythm-phase (line-box tops 7px past a rule = rules under baselines).
			// Margin collapsing makes one-shot arithmetic unreliable, so measure and
			// correct until the target holds. Gated to pages with a .prose flow; the
			// index has its own snap in PostStream.
			const prose = document.querySelector('main.post article .prose');
			if (prose) {
				const rootStyle = () => getComputedStyle(document.documentElement);
				const cellSize = () => parseFloat(rootStyle().getPropertyValue('--cell')) || 24;
				const phase = () => parseFloat(rootStyle().getPropertyValue('--rhythm-phase')) || 0;
				const BOXY = 'header.entry, .toc, figure.fig, figure.code, .tbl-wrap, .callout, pre';
				const inFlow = (el: HTMLElement) =>
					el.offsetParent !== null && getComputedStyle(el).position !== 'fixed';

				const nudge = (
					el: HTMLElement,
					side: 'marginTop' | 'marginBottom',
					measure: () => number | null,
					target: number,
					cell: number,
				) => {
					for (let i = 0; i < 4; i++) {
						const y = measure();
						if (y == null) return;
						const rem = (target - (y % cell) + cell * 2) % cell;
						if (rem < 0.5 || rem > cell - 0.5) return;
						const cur = parseFloat(getComputedStyle(el)[side]) || 0;
						el.style[side] = `${cur + rem}px`;
					}
				};

				const snap = () => {
					const cell = cellSize();
					const blocks = Array.from(
						document.querySelectorAll<HTMLElement>(`main.post article :is(${BOXY})`),
					).filter(
						// skip nested matches (e.g. the pre inside a code shell) — only
						// blocks that participate in the article flow get snapped
						(el) => inFlow(el) && !el.parentElement?.closest(BOXY),
					);
					blocks.forEach((el) => {
						el.style.marginTop = '';
						el.style.marginBottom = '';
					});
					blocks.forEach((el) => {
						// the masthead starts the page; only its bottom boundary matters
						if (!el.matches('header.entry')) {
							nudge(el, 'marginTop', () => el.getBoundingClientRect().top + window.scrollY, 0, cell);
						}
						const next = el.nextElementSibling as HTMLElement | null;
						if (!next) return;
						const targetOffset = next.matches(BOXY) ? 0 : phase();
						nudge(
							el,
							'marginBottom',
							() => next.getBoundingClientRect().top + window.scrollY,
							targetOffset,
							cell,
						);
					});
				};

				let snapTimer = 0;
				const requestSnap = () => {
					window.clearTimeout(snapTimer);
					snapTimer = window.setTimeout(snap, 80);
				};
				snap();
				window.addEventListener('load', requestSnap);
				window.addEventListener('resize', requestSnap);
				if (document.fonts?.ready) document.fonts.ready.then(requestSnap);
			}

			// dev aid: ?rhythm overlays the cell boundaries (line-box targets sit
			// --rhythm-phase below the red lines)
			if (new URLSearchParams(location.search).has('rhythm')) {
				const cell = parseFloat(getComputedStyle(document.documentElement).getPropertyValue('--cell')) || 24;
				const overlay = document.createElement('div');
				overlay.style.cssText =
					'position:absolute;left:0;top:0;width:100%;pointer-events:none;z-index:99;' +
					`height:${document.documentElement.scrollHeight}px;` +
					`background-image:repeating-linear-gradient(to bottom, rgba(220,40,40,.45) 0 1px, transparent 1px ${cell}px);`;
				document.body.appendChild(overlay);
			}

			const tocLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('.toc a'));
			const sections = Array.from(document.querySelectorAll<HTMLElement>('article h2[id]'));
			if (tocLinks.length && sections.length) {
				const updateToc = () => {
					const marker = window.scrollY + 120;
					let current: string | null = sections[0].id;
					sections.forEach((section) => {
						if (section.offsetTop <= marker) current = section.id;
					});
					tocLinks.forEach((link) => {
						link.classList.toggle('cur', link.getAttribute('href') === `#${current}`);
					});
				};
				window.addEventListener('scroll', updateToc, { passive: true });
				updateToc();
			}
		</script>
	</body>
</html>
